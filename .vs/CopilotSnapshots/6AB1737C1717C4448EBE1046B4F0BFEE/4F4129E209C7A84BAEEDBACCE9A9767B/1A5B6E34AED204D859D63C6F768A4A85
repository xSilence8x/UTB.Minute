# Run with verbosity
dotnet test UTB.Minute.WebApi.Tests --logger "console;verbosity=detailed"

# Run specific class
dotnet test --filter "ClassName=MealEndpointsTests"

# Run specific test
dotnet test --filter "Name=CreateMeal_WithValidData_ShouldReturnCreated"
```

### Visual Studio
