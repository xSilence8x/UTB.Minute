public class OrderEndpointsTests : IAsyncLifetime
{
    private WebApplicationFactory<Program> _factory = null!;
    private HttpClient _httpClient = null!;

    public async Task InitializeAsync()
    {
        _factory = new WebApplicationFactory<Program>();
        _httpClient = _factory.CreateClient();

        // Reset database
        await _httpClient.PostAsync("/reset-database", null);
    }

    public async Task DisposeAsync()
    {
        _httpClient?.Dispose();
        await _factory.DisposeAsync();
    }

    [Fact]
    public async Task GetOrders_ShouldReturnAllOrders()
    {
        // Act
        var response = await _httpClient.GetAsync("/orders");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetActiveOrders_ShouldReturnOnlyActiveOrders()
    {
        // Act
        var response = await _httpClient.GetAsync("/orders/active");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithValidId_ShouldReturnOrder()
    {
        // Act
        var response = await _httpClient.GetAsync("/orders/1");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await _httpClient.GetAsync("/orders/999");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateOrder_WithValidData_ShouldReturnCreated()
    {
        // Arrange
        var createOrderDto = new
        {
            menuItemId = 1,
            studentName = "Jan Nový"
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createOrderDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PostAsync("/orders", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();
    }

    [Fact]
    public async Task CreateOrder_WithInvalidMenuItem_ShouldReturnBadRequest()
    {
        // Arrange
        var createOrderDto = new
        {
            menuItemId = 999,
            studentName = "Jan Nový"
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createOrderDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PostAsync("/orders", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task CreateOrder_WithSoldOutMenuItem_ShouldReturnBadRequest()
    {
        // Arrange - create a menu item with 0 portions
        var createMenuItemDto = new
        {
            mealId = 1,
            date = System.DateOnly.FromDateTime(System.DateTime.Today),
            availablePortions = 0
        };
        var menuItemContent = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createMenuItemDto),
            System.Text.Encoding.UTF8,
            "application/json");
        await _httpClient.PostAsync("/menu-items", menuItemContent);

        var createOrderDto = new
        {
            menuItemId = 3, // the newly created menu item
            studentName = "Jan Nový"
        };
        var orderContent = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createOrderDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PostAsync("/orders", orderContent);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task CreateOrder_ShouldDecreaseAvailablePortions()
    {
        // Arrange
        var getMenuItemsBefore = await _httpClient.GetAsync("/menu-items/1");
        var contentBefore = await getMenuItemsBefore.Content.ReadAsStringAsync();
        var portionsBefore = contentBefore.Contains("\"availablePortions\":10");

        var createOrderDto = new
        {
            menuItemId = 1,
            studentName = "Jan Nový"
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createOrderDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        await _httpClient.PostAsync("/orders", content);

        var getMenuItemsAfter = await _httpClient.GetAsync("/menu-items/1");
        var contentAfter = await getMenuItemsAfter.Content.ReadAsStringAsync();
        var portionsAfter = contentAfter.Contains("\"availablePortions\":9");

        // Assert
        portionsBefore.Should().BeTrue();
        portionsAfter.Should().BeTrue();
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToReady_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new
        {
            state = 1 // Ready
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateStateDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/orders/1/state", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NoContent);
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToCancelled_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new
        {
            state = 2 // Cancelled
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateStateDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/orders/1/state", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NoContent);
    }

    [Fact]
    public async Task UpdateOrderState_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateStateDto = new
        {
            state = 1 // Ready
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateStateDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/orders/999/state", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateOrderState_InvalidTransition_ShouldReturnBadRequest()
    {
        // Arrange - first change order to Cancelled
        var cancelStateDto = new
        {
            state = 2 // Cancelled
        };
        var cancelContent = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(cancelStateDto),
            System.Text.Encoding.UTF8,
            "application/json");
        await _httpClient.PutAsync("/orders/1/state", cancelContent);

        // Try to change from Cancelled to Ready (invalid)
        var updateStateDto = new
        {
            state = 1 // Ready
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateStateDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/orders/1/state", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task UpdateOrderState_ToCompleted_ShouldReturnNoContent()
    {
        // Arrange - first change to Ready
        var readyStateDto = new
        {
            state = 1 // Ready
        };
        var readyContent = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(readyStateDto),
            System.Text.Encoding.UTF8,
            "application/json");
        await _httpClient.PutAsync("/orders/1/state", readyContent);

        // Then change to Completed
        var completedStateDto = new
        {
            state = 3 // Completed
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(completedStateDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/orders/1/state", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NoContent);
    }
}
