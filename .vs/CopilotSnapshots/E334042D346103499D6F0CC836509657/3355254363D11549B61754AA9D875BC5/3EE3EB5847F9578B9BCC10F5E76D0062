namespace UTB.Minute.WebApi.Tests;

public class MealEndpointsTests : IAsyncLifetime
{
    private WebApiFactory _factory = null!;
    private HttpClient _httpClient = null!;

    public async Task InitializeAsync()
    {
        _factory = new WebApiFactory();
        _httpClient = _factory.CreateClient();

        // Reset database before each test
        await _httpClient.PostAsync("/reset-database", null);
    }

    public async Task DisposeAsync()
    {
        _httpClient?.Dispose();
        await _factory.DisposeAsync();
    }

    [Fact]
    public async Task GetMeals_ShouldReturnAllMeals()
    {
        // Act
        var response = await _httpClient.GetAsync("/meals");
        var content = await response.Content.ReadAsStringAsync();

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.OK);
        content.Should().NotBeEmpty();
    }

    [Fact]
    public async Task GetMealById_WithValidId_ShouldReturnMeal()
    {
        // Act
        var response = await _httpClient.GetAsync("/meals/1");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetMealById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await _httpClient.GetAsync("/meals/999");

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateMeal_WithValidData_ShouldReturnCreated()
    {
        // Arrange
        var createMealDto = new
        {
            name = "Nový pokrm",
            description = "Popis pokrmu",
            price = 150.00m
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(createMealDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PostAsync("/meals", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();
    }

    [Fact]
    public async Task UpdateMeal_WithValidData_ShouldReturnNoContent()
    {
        // Arrange
        var updateMealDto = new
        {
            name = "Aktualizovaný pokrm",
            description = "Nový popis",
            price = 200.00m,
            isActive = true
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateMealDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/meals/1", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NoContent);
    }

    [Fact]
    public async Task UpdateMeal_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateMealDto = new
        {
            name = "Pokrm",
            description = "Popis",
            price = 150.00m,
            isActive = true
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateMealDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        var response = await _httpClient.PutAsync("/meals/999", content);

        // Assert
        response.StatusCode.Should().Be(System.Net.HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateMeal_WithDeactivation_ShouldSetIsActiveToFalse()
    {
        // Arrange
        var updateMealDto = new
        {
            name = "Pokrm",
            description = "Popis",
            price = 150.00m,
            isActive = false
        };
        var content = new StringContent(
            System.Text.Json.JsonSerializer.Serialize(updateMealDto),
            System.Text.Encoding.UTF8,
            "application/json");

        // Act
        await _httpClient.PutAsync("/meals/1", content);
        var getResponse = await _httpClient.GetAsync("/meals/1");
        var responseContent = await getResponse.Content.ReadAsStringAsync();

        // Assert
        responseContent.Should().Contain("\"isActive\":false");
    }
}

