/// <summary>
/// Integration tests for Order endpoints.
/// </summary>
[Collection("Database collection")]
public class OrderEndpointsTests(TestFixture fixture)
{
    private readonly TestFixture fixture = fixture;

    [Fact]
    public async Task GetOrders_ShouldReturnAllOrders()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetActiveOrders_ShouldReturnOnlyActiveOrders()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/active", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithValidId_ShouldReturnOrder()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/1", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/999", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateOrder_WithValidData_ShouldReturnCreatedAndPersistsOrder()
    {
        // Arrange
        var createOrderDto = new CreateOrderDto
        {
            MenuItemId = 1,
            StudentName = "Test Student"
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync(
            "/orders",
            createOrderDto,
            TestContext.Current.CancellationToken);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();

        var responseContent = await response.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);
        var orderDto = JsonSerializer.Deserialize<OrderDto>(responseContent);

        orderDto.Should().NotBeNull();
        orderDto!.StudentName.Should().Be(createOrderDto.StudentName);
        orderDto.MenuItemId.Should().Be(createOrderDto.MenuItemId);

        // Assert - Database state
        using var context = fixture.CreateContext();
        var orderInDb = await context.Orders.FindAsync(orderDto.Id, TestContext.Current.CancellationToken);

        orderInDb.Should().NotBeNull();
        orderInDb!.StudentName.Should().Be(createOrderDto.StudentName);
        orderInDb.MenuItemId.Should().Be(createOrderDto.MenuItemId);
        orderInDb.State.Should().Be(OrderState.Preparing);
    }

    [Fact]
    public async Task CreateOrder_WithInvalidMenuItem_ShouldReturnBadRequest()
    {
        // Arrange
        var createOrderDto = new CreateOrderDto
        {
            MenuItemId = 999,
            StudentName = "Test Student"
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync(
            "/orders",
            createOrderDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task CreateOrder_WithSoldOutMenuItem_ShouldReturnBadRequest()
    {
        // Arrange - create a menu item with 0 portions
        var createMenuItemDto = new CreateMenuItemDto
        {
            MealId = 1,
            Date = DateOnly.FromDateTime(DateTime.Today),
            AvailablePortions = 0
        };

        await fixture.HttpClient.PostAsJsonAsync(
            "/menu-items",
            createMenuItemDto,
            TestContext.Current.CancellationToken);

        // Get the newly created menu item ID
        var menuItemsResponse = await fixture.HttpClient.GetAsync("/menu-items", TestContext.Current.CancellationToken);
        var menuItemsContent = await menuItemsResponse.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);
        var menuItems = JsonSerializer.Deserialize<JsonElement>(menuItemsContent);

        var lastMenuItem = menuItems.Value.EnumerateArray().Last();
        var newMenuItemId = lastMenuItem.GetProperty("id").GetInt32();

        var createOrderDto = new CreateOrderDto
        {
            MenuItemId = newMenuItemId,
            StudentName = "Test Student"
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync(
            "/orders",
            createOrderDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task CreateOrder_ShouldDecreaseAvailablePortions()
    {
        // Arrange - Get initial portion count
        var getMenuItemResponse = await fixture.HttpClient.GetAsync(
            "/menu-items/1",
            TestContext.Current.CancellationToken);
        var initialContent = await getMenuItemResponse.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);
        var initialMenuItem = JsonSerializer.Deserialize<MenuItemDto>(initialContent);
        var initialPortions = initialMenuItem!.AvailablePortions;

        var createOrderDto = new CreateOrderDto
        {
            MenuItemId = 1,
            StudentName = "Test Student"
        };

        // Act
        await fixture.HttpClient.PostAsJsonAsync(
            "/orders",
            createOrderDto,
            TestContext.Current.CancellationToken);

        // Assert - Check portion count decreased
        var getFinalResponse = await fixture.HttpClient.GetAsync(
            "/menu-items/1",
            TestContext.Current.CancellationToken);
        var finalContent = await getFinalResponse.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);
        var finalMenuItem = JsonSerializer.Deserialize<MenuItemDto>(finalContent);

        finalMenuItem!.AvailablePortions.Should().Be(initialPortions - 1);
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToReady_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Ready
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            updateStateDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1, TestContext.Current.CancellationToken);
        order.Should().NotBeNull();
        order!.State.Should().Be(OrderState.Ready);
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToCancelled_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Cancelled
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            updateStateDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1, TestContext.Current.CancellationToken);
        order.Should().NotBeNull();
        order!.State.Should().Be(OrderState.Cancelled);
    }

    [Fact]
    public async Task UpdateOrderState_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Ready
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/orders/999/state",
            updateStateDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateOrderState_InvalidTransition_ShouldReturnBadRequest()
    {
        // Arrange - first change to Cancelled
        var cancelStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Cancelled
        };
        await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            cancelStateDto,
            TestContext.Current.CancellationToken);

        // Try invalid transition: Cancelled → Ready
        var updateStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Ready
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            updateStateDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task UpdateOrderState_ToCompleted_ShouldReturnNoContent()
    {
        // Arrange - first change to Ready
        var readyStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Ready
        };
        await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            readyStateDto,
            TestContext.Current.CancellationToken);

        // Then change to Completed
        var completedStateDto = new UpdateOrderStateDto
        {
            State = OrderStateDto.Completed
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/orders/1/state",
            completedStateDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1, TestContext.Current.CancellationToken);
        order.Should().NotBeNull();
        order!.State.Should().Be(OrderState.Completed);
    }
}
