/// <summary>
/// Integration tests for Meal endpoints.
/// Tests verify HTTP status codes, response content, and database state.
/// </summary>
[Collection("Database collection")]
public class MealEndpointsTests(TestFixture fixture)
{
    private readonly TestFixture fixture = fixture;

    [Fact]
    public async Task GetMeals_ShouldReturnAllMeals()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals", TestContext.Current.CancellationToken);
        var content = await response.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
        content.Should().NotBeEmpty();
        content.Should().Contain("Kuřecí řízek");
    }

    [Fact]
    public async Task GetMealById_WithValidId_ShouldReturnMeal()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals/1", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetMealById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals/999", TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateMeal_WithValidData_ShouldReturnCreatedAndPersistsMeal()
    {
        // Arrange
        var createMealDto = new CreateMealDto
        {
            Name = "Test Pokrm",
            Description = "Testovací pokrm",
            Price = 150.00m
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync(
            "/meals",
            createMealDto,
            TestContext.Current.CancellationToken);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();

        var responseContent = await response.Content.ReadAsStringAsync(TestContext.Current.CancellationToken);
        var mealDto = JsonSerializer.Deserialize<MealDto>(responseContent);

        mealDto.Should().NotBeNull();
        mealDto!.Name.Should().Be(createMealDto.Name);
        mealDto.Description.Should().Be(createMealDto.Description);
        mealDto.Price.Should().Be(createMealDto.Price);
        mealDto.IsActive.Should().BeTrue();

        // Assert - Database state
        using var context = fixture.CreateContext();
        var mealInDb = await context.Meals.FindAsync(mealDto.Id, TestContext.Current.CancellationToken);

        mealInDb.Should().NotBeNull();
        mealInDb!.Name.Should().Be(createMealDto.Name);
        mealInDb.Price.Should().Be(createMealDto.Price);
        mealInDb.IsActive.Should().BeTrue();
    }

    [Fact]
    public async Task UpdateMeal_WithValidData_ShouldReturnNoContentAndUpdateDatabase()
    {
        // Arrange
        var updateMealDto = new UpdateMealDto
        {
            Name = "Aktualizovaný pokrm",
            Description = "Nový popis",
            Price = 200.00m,
            IsActive = true
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/meals/1",
            updateMealDto,
            TestContext.Current.CancellationToken);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Assert - Database state
        using var context = fixture.CreateContext();
        var meal = await context.Meals.FindAsync(1, TestContext.Current.CancellationToken);

        meal.Should().NotBeNull();
        meal!.Name.Should().Be(updateMealDto.Name);
        meal.Description.Should().Be(updateMealDto.Description);
        meal.Price.Should().Be(updateMealDto.Price);
    }

    [Fact]
    public async Task UpdateMeal_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateMealDto = new UpdateMealDto
        {
            Name = "Test",
            Description = "Test",
            Price = 100.00m,
            IsActive = true
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/meals/999",
            updateMealDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateMeal_WithDeactivation_ShouldSetIsActiveToFalse()
    {
        // Arrange
        var updateMealDto = new UpdateMealDto
        {
            Name = "Kuřecí řízek s bramborem",
            Description = "Klasický český oběd s kuřecím řízkem, bramborem a tatarkou.",
            Price = 85.00m,
            IsActive = false
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync(
            "/meals/1",
            updateMealDto,
            TestContext.Current.CancellationToken);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var meal = await context.Meals.FindAsync(1, TestContext.Current.CancellationToken);

        meal.Should().NotBeNull();
        meal!.IsActive.Should().BeFalse();
    }
}

