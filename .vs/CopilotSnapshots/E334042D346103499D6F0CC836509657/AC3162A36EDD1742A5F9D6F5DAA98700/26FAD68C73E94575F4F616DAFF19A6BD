namespace UTB.Minute.WebApi.Tests;

using System.Net;
using System.Text.Json;

/// <summary>
/// Integration tests for Meal endpoints using Aspire infrastructure.
/// Each test uses the shared TestFixture which starts PostgreSQL and Web API.
/// </summary>
[Collection("Database collection")]
public class MealEndpointsTests(TestFixture fixture)
{
    private readonly TestFixture fixture = fixture;

    [Fact]
    public async Task GetMeals_ShouldReturnAllMeals()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals");
        var content = await response.Content.ReadAsStringAsync();

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
        content.Should().NotBeEmpty();
        content.Should().Contain("Kuřecí řízek");
    }

    [Fact]
    public async Task GetMealById_WithValidId_ShouldReturnMeal()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals/1");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetMealById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/meals/999");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateMeal_WithValidData_ShouldReturnCreatedAndPersistsMeal()
    {
        // Arrange
        var createMealDto = new { Name = "Test Pokrm", Description = "Testovací pokrm", Price = 150.00m };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync("/meals", createMealDto);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();

        var responseContent = await response.Content.ReadAsStringAsync();
        var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        var mealDto = JsonSerializer.Deserialize<dynamic>(responseContent, options);

        // Assert - Database state
        using var context = fixture.CreateContext();
        var meal = await context.Meals.FindAsync(1);
        meal.Should().NotBeNull();
    }

    [Fact]
    public async Task UpdateMeal_WithValidData_ShouldReturnNoContentAndUpdateDatabase()
    {
        // Arrange
        var updateMealDto = new
        {
            Name = "Aktualizovaný pokrm",
            Description = "Nový popis",
            Price = 200.00m,
            IsActive = true
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/meals/1", updateMealDto);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Assert - Database state
        using var context = fixture.CreateContext();
        var meal = await context.Meals.FindAsync(1);
        meal.Should().NotBeNull();
        meal!.Name.Should().Be(updateMealDto.Name);
    }

    [Fact]
    public async Task UpdateMeal_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateMealDto = new
        {
            Name = "Test",
            Description = "Test",
            Price = 100.00m,
            IsActive = true
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/meals/999", updateMealDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateMeal_WithDeactivation_ShouldSetIsActiveToFalse()
    {
        // Arrange
        var updateMealDto = new
        {
            Name = "Kuřecí řízek s bramborem",
            Description = "Klasický český oběd s kuřecím řízkem, bramborem a tatarkou.",
            Price = 85.00m,
            IsActive = false
        };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/meals/1", updateMealDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var meal = await context.Meals.FindAsync(1);
        meal.Should().NotBeNull();
        meal!.IsActive.Should().BeFalse();
    }
}

