/// <summary>
/// Integration tests for Order endpoints.
/// </summary>
[Collection("Database collection")]
public class OrderEndpointsTests(TestFixture fixture)
{
    private readonly TestFixture fixture = fixture;

    [Fact]
    public async Task GetOrders_ShouldReturnAllOrders()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetActiveOrders_ShouldReturnOnlyActiveOrders()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/active");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithValidId_ShouldReturnOrder()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/1");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.OK);
    }

    [Fact]
    public async Task GetOrderById_WithInvalidId_ShouldReturnNotFound()
    {
        // Act
        var response = await fixture.HttpClient.GetAsync("/orders/999");

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task CreateOrder_WithValidData_ShouldReturnCreatedAndPersistsOrder()
    {
        // Arrange
        var createOrderDto = new
        {
            MenuItemId = 1,
            StudentName = "Test Student"
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync("/orders", createOrderDto);

        // Assert - HTTP response
        response.StatusCode.Should().Be(HttpStatusCode.Created);
        response.Headers.Location.Should().NotBeNull();
    }

    [Fact]
    public async Task CreateOrder_WithInvalidMenuItem_ShouldReturnBadRequest()
    {
        // Arrange
        var createOrderDto = new
        {
            MenuItemId = 999,
            StudentName = "Test Student"
        };

        // Act
        var response = await fixture.HttpClient.PostAsJsonAsync("/orders", createOrderDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task CreateOrder_ShouldDecreaseAvailablePortions()
    {
        // Arrange - Get initial portion count
        var getMenuItemResponse = await fixture.HttpClient.GetAsync("/menu-items/1");
        var initialContent = await getMenuItemResponse.Content.ReadAsStringAsync();
        var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        var initialMenuItem = JsonSerializer.Deserialize<JsonElement>(initialContent, options);
        var initialPortions = initialMenuItem.GetProperty("availablePortions").GetInt32();

        var createOrderDto = new
        {
            MenuItemId = 1,
            StudentName = "Test Student"
        };

        // Act
        await fixture.HttpClient.PostAsJsonAsync("/orders", createOrderDto);

        // Assert - Check portion count decreased
        var getFinalResponse = await fixture.HttpClient.GetAsync("/menu-items/1");
        var finalContent = await getFinalResponse.Content.ReadAsStringAsync();
        var finalMenuItem = JsonSerializer.Deserialize<JsonElement>(finalContent, options);
        var finalPortions = finalMenuItem.GetProperty("availablePortions").GetInt32();

        finalPortions.Should().Be(initialPortions - 1);
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToReady_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new { State = 1 }; // Ready

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", updateStateDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1);
        order.Should().NotBeNull();
        order!.State.Should().Be(global::UTB.Minute.Db.Entities.OrderState.Ready);
    }

    [Fact]
    public async Task UpdateOrderState_FromPreparingToCancelled_ShouldReturnNoContent()
    {
        // Arrange
        var updateStateDto = new { State = 2 }; // Cancelled

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", updateStateDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1);
        order.Should().NotBeNull();
        order!.State.Should().Be(global::UTB.Minute.Db.Entities.OrderState.Cancelled);
    }

    [Fact]
    public async Task UpdateOrderState_WithInvalidId_ShouldReturnNotFound()
    {
        // Arrange
        var updateStateDto = new { State = 1 };

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/orders/999/state", updateStateDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NotFound);
    }

    [Fact]
    public async Task UpdateOrderState_InvalidTransition_ShouldReturnBadRequest()
    {
        // Arrange - first change to Cancelled
        var cancelStateDto = new { State = 2 }; // Cancelled
        await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", cancelStateDto);

        // Try invalid transition: Cancelled → Ready
        var updateStateDto = new { State = 1 }; // Ready

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", updateStateDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.BadRequest);
    }

    [Fact]
    public async Task UpdateOrderState_ToCompleted_ShouldReturnNoContent()
    {
        // Arrange - first change to Ready
        var readyStateDto = new { State = 1 }; // Ready
        await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", readyStateDto);

        // Then change to Completed
        var completedStateDto = new { State = 3 }; // Completed

        // Act
        var response = await fixture.HttpClient.PutAsJsonAsync("/orders/1/state", completedStateDto);

        // Assert
        response.StatusCode.Should().Be(HttpStatusCode.NoContent);

        // Verify in database
        using var context = fixture.CreateContext();
        var order = await context.Orders.FindAsync(1);
        order.Should().NotBeNull();
        order!.State.Should().Be(global::UTB.Minute.Db.Entities.OrderState.Completed);
    }
}
